rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // 1. Primitive Definitions & Global Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }
    
    // Auth tokens NEVER contain custom claims in this environment.
    // We strictly use the designated admin email for RBAC elevation.
    function isAdmin() { 
      return isVerified() && request.auth.token.email == "princeradadia@gmail.com"; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // 2. Validation Blueprints (Strict Schema Enforcement)
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('mobilityFirst' in data) || data.mobilityFirst is bool) &&
             // Prevent "Shadow Fields" via strict size check
             data.keys().size() <= 6;
    }

    function isValidQueueToken(data) {
      return data.keys().hasAll(['userId', 'venueId', 'serviceType', 'status', 'joinedAt']) &&
             data.userId == request.auth.uid &&
             data.venueId is string && isValidId(data.venueId) &&
             data.serviceType in ['concession', 'restroom', 'entry', 'exit'] &&
             data.status in ['waiting', 'called', 'completed', 'cancelled'] &&
             data.joinedAt is timestamp &&
             data.keys().size() <= 8;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'role', 'content', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() <= 2000 &&
             data.timestamp is timestamp &&
             data.keys().size() == 4;
    }

    function isValidAnalyticsLog(data) {
      return data.keys().hasAll(['type', 'venueId', 'payload', 'timestamp']) &&
             data.type is string && data.type.size() <= 64 &&
             data.venueId is string && isValidId(data.venueId) &&
             data.payload is map &&
             data.timestamp is timestamp &&
             data.keys().size() <= 7;
    }

    // ===============================================================
    // 3. Domain match blocks
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidId(userId) && (
        // Action: Profile Refinement
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'mobilityFirst', 'updatedAt']) &&
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        isValidUser(incoming())
      ) || isAdmin();
    }

    match /queues/{tokenId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isVerified() && isValidId(tokenId) && 
                      isValidQueueToken(incoming()) &&
                      incoming().status == 'waiting' &&
                      incoming().joinedAt == request.time &&
                      exists(/databases/$(database)/documents/venues/$(incoming().venueId));

      allow update: if isVerified() && isValidId(tokenId) && (
        (
          // Action: User-Initiated Lifecycle Change
          resource.data.userId == request.auth.uid &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
          incoming().status == 'cancelled' &&
          existing().status == 'waiting' &&
          incoming().updatedAt == request.time &&
          isValidQueueToken(incoming())
        ) || isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /venues/{venueId} {
      // 100% Read/Write isolation for static venue telemetry
      allow read: if true; 
      allow write: if isAdmin() && isValidId(venueId);
    }

    match /chats/{chatId}/messages/{messageId} {
      // Identity deriviation via path segments
      function isChatParticipant(cid) { return isVerified() && request.auth.uid == cid; }

      allow get, list: if isChatParticipant(chatId) || isAdmin();
      
      allow create: if isChatParticipant(chatId) && 
                      isValidId(chatId) &&
                      isValidId(messageId) &&
                      isValidChatMessage(incoming());
                      
      allow update, delete: if isAdmin();
    }

    match /venue_analytics/{logId} {
      allow create: if isVerified() && isValidId(logId) && isValidAnalyticsLog(incoming());
      allow get: if isAdmin();
      allow list: if isAdmin();
    }
  }
}
